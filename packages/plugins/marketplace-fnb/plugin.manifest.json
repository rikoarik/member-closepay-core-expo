{
  "id": "marketplace-fnb",
  "name": "Marketplace F&B",
  "description": "Food & Beverage ordering plugin with dine-in, take away, and delivery options",
  "version": "1.0.0",
  "type": "segment-plugin",
  "author": "Closepay Team",
  "dependencies": [
    "balance",
    "payment"
  ],
  "exports": {
    "components": [
      "FnBItemCard",
      "FnBCategoryTabs",
      "FnBCartBar",
      "FnBItemDetailSheet",
      "MerchantHeader",
      "FnBFavorites"
    ],
    "screens": {
      "FnB": "FnBScreen",
      "FnBMerchantDetail": "FnBMerchantDetailScreen",
      "FnBCheckout": "FnBCheckoutScreen",
      "FnBScan": "FnBScanScreen",
      "FnBFavorites": "FnBFavoritesScreen",
      "FnBOrderStatus": "FnBOrderStatusScreen",
      "FnBOrderTracking": "FnBOrderTrackingScreen",
      "FnBChatDriver": "FnBChatDriverScreen"
    },
    "hooks": [
      "useFnBData",
      "useFnBCart"
    ],
    "models": [
      "FnBItem",
      "FnBVariant",
      "FnBAddon",
      "FnBCategory",
      "FnBOrder",
      "FnBOrderItem",
      "OrderType",
      "EntryPoint",
      "OrderStatus",
      "FnBStore",
      "FnBQRData",
      "OperatingHour",
      "DeliverySettings"
    ],
    "tabs": {
      "fnb": "FnBTab",
      "fnb-order": "FnBOrderTab",
      "fnb-history": "FnBHistoryTab",
      "fnb-balance": "FnBBalanceTab"
    },
    "widgets": {
      "fnb-recent-orders": "FnBRecentOrders",
      "fnb-order-floating": "FnBOrderFloatingWidget"
    }
  },
  "routes": [
    {
      "name": "FnB",
      "path": "/fnb",
      "component": "FnBScreen",
      "permissions": [
        "read:fnb"
      ],
      "meta": {
        "title": "Pesan Makanan",
        "showInMenu": true
      }
    },
    {
      "name": "FnBMerchantDetail",
      "path": "/fnb/merchant-detail",
      "component": "FnBMerchantDetailScreen",
      "permissions": [
        "read:fnb"
      ],
      "meta": {
        "title": "Detail Merchant",
        "showInMenu": false
      }
    },
    {
      "name": "FnBCheckout",
      "path": "/fnb/checkout",
      "component": "FnBCheckoutScreen",
      "permissions": [
        "write:fnb"
      ],
      "meta": {
        "title": "Checkout",
        "showInMenu": false
      }
    },
    {
      "name": "FnBScan",
      "path": "/fnb/scan",
      "component": "FnBScanScreen",
      "permissions": [
        "write:fnb"
      ],
      "meta": {
        "title": "Scan QR",
        "showInMenu": false
      }
    },
    {
      "name": "FnBFavorites",
      "path": "/fnb/favorites",
      "component": "FnBFavoritesScreen",
      "permissions": [
        "read:fnb"
      ],
      "meta": {
        "title": "Favorites",
        "showInMenu": false
      }
    },
    {
      "name": "FnBOrderStatus",
      "path": "/fnb/order-status",
      "component": "FnBOrderStatusScreen",
      "permissions": [
        "read:fnb"
      ],
      "meta": {
        "title": "Status Pesanan",
        "showInMenu": false
      }
    },
    {
      "name": "FnBOrderTracking",
      "path": "/fnb/order-tracking",
      "component": "FnBOrderTrackingScreen",
      "permissions": [
        "read:fnb"
      ],
      "meta": {
        "title": "Lacak Pesanan",
        "showInMenu": false
      }
    },
    {
      "name": "FnBChatDriver",
      "path": "/fnb/chat-driver",
      "component": "FnBChatDriverScreen",
      "permissions": [
        "read:fnb"
      ],
      "meta": {
        "title": "Chat",
        "showInMenu": false
      }
    }
  ],
  "permissions": [
    "read:fnb",
    "write:fnb"
  ]
}