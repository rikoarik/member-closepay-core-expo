{
  "id": "marketplace-fnb",
  "name": "Marketplace F&B",
  "description": "Food & Beverage ordering plugin with dine-in, take away, and delivery options",
  "version": "1.0.0",
  "type": "segment-plugin",
  "author": "Closepay Team",
  "dependencies": [
    "balance",
    "payment"
  ],
  "exports": {
    "components": [
      "FnBItemCard",
      "FnBCategoryTabs",
      "FnBCartBar",
      "FnBItemDetailSheet",
      "MerchantHeader",
      "FnBFavorites"
    ],
    "screens": {
      "FnB": "FnBScreen",
      "FnBMerchantDetail": "FnBMerchantDetailScreen",
      "FnBCheckout": "FnBCheckoutScreen",
      "FnBScan": "FnBScanScreen",
      "FnBFavorites": "FnBFavoritesScreen",
      "FnBProductSearch": "FnBProductSearchScreen",
      "FnBProductSearchResults": "FnBProductSearchResultsScreen",
      "FnBNearby": "FnBNearbyScreen",
      "FnBCheapDelivery": "FnBCheapDeliveryScreen",
      "FnBAllMerchants": "FnBAllMerchantsScreen",
      "FnBOrderStatus": "FnBOrderStatusScreen",
      "FnBPaymentSuccess": "FnBPaymentSuccessScreen",
      "FnBOrderTracking": "FnBOrderTrackingScreen",
      "FnBChatDriver": "FnBChatDriverScreen",
      "FnBOrderHistory": "FnBOrderHistoryScreen"
    },
    "hooks": [
      "useFnBData",
      "useFnBCart",
      "useFnBFavorites",
      "useFnBStoreFavorites"
    ],
    "models": [
      "FnBItem",
      "FnBVariant",
      "FnBAddon",
      "FnBCategory",
      "FnBOrder",
      "FnBOrderItem",
      "OrderType",
      "EntryPoint",
      "OrderStatus",
      "FnBStore",
      "FnBQRData",
      "OperatingHour",
      "DeliverySettings"
    ],
    "tabs": {
      "fnb": "FnBTab",
      "fnb-order": "FnBOrderTab",
      "fnb-history": "FnBHistoryTab",
      "fnb-balance": "FnBBalanceTab"
    },
    "widgets": {
      "fnb-recent-orders": "FnBRecentOrders",
      "fnb-order-floating": "FnBOrderFloatingWidget"
    }
  },
  "tabs": [
    { "id": "fnb", "component": "FnBTab", "labelKey": "home.fnb", "order": 1 }
  ],
  "quickMenuItems": [
    { "id": "fnb", "component": "FnBScreen", "labelKey": "home.fnb", "icon": "shop", "route": "FnB", "order": 1 }
  ],
  "routes": [
    {
      "name": "FnB",
      "path": "/fnb",
      "component": "FnBScreen",
      "permissions": [
        "read:fnb"
      ],
      "meta": {
        "title": "Pesan Makanan",
        "showInMenu": true
      }
    },
    {
      "name": "FnBMerchantDetail",
      "path": "/fnb/merchant-detail",
      "component": "FnBMerchantDetailScreen",
      "permissions": [
        "read:fnb"
      ],
      "meta": {
        "title": "Detail Merchant",
        "showInMenu": false
      }
    },
    {
      "name": "FnBCheckout",
      "path": "/fnb/checkout",
      "component": "FnBCheckoutScreen",
      "permissions": [
        "write:fnb"
      ],
      "meta": {
        "title": "Checkout",
        "showInMenu": false
      }
    },
    {
      "name": "FnBScan",
      "path": "/fnb/scan",
      "component": "FnBScanScreen",
      "permissions": [
        "write:fnb"
      ],
      "meta": {
        "title": "Scan QR",
        "showInMenu": false
      }
    },
    {
      "name": "FnBFavorites",
      "path": "/fnb/favorites",
      "component": "FnBFavoritesScreen",
      "permissions": [
        "read:fnb"
      ],
      "meta": {
        "title": "Favorites",
        "showInMenu": false
      }
    },
    {
      "name": "FnBOrderStatus",
      "path": "/fnb/order-status",
      "component": "FnBOrderStatusScreen",
      "permissions": [
        "read:fnb"
      ],
      "meta": {
        "title": "Status Pesanan",
        "showInMenu": false
      }
    },
    {
      "name": "FnBPaymentSuccess",
      "path": "/fnb/payment-success",
      "component": "FnBPaymentSuccessScreen",
      "permissions": [
        "read:fnb"
      ],
      "meta": {
        "title": "Pembayaran Berhasil",
        "showInMenu": false
      }
    },
    {
      "name": "FnBOrderTracking",
      "path": "/fnb/order-tracking",
      "component": "FnBOrderTrackingScreen",
      "permissions": [
        "read:fnb"
      ],
      "meta": {
        "title": "Lacak Pesanan",
        "showInMenu": false
      }
    },
    {
      "name": "FnBChatDriver",
      "path": "/fnb/chat-driver",
      "component": "FnBChatDriverScreen",
      "permissions": [
        "read:fnb"
      ],
      "meta": {
        "title": "Chat",
        "showInMenu": false
      }
    },
    {
      "name": "FnBOrderHistory",
      "path": "/fnb/order-history",
      "component": "FnBOrderHistoryScreen",
      "permissions": [
        "read:fnb"
      ],
      "meta": {
        "title": "Riwayat Order",
        "showInMenu": false
      }
    },
    {
      "name": "FnBProductSearch",
      "path": "/fnb/search",
      "component": "FnBProductSearchScreen",
      "permissions": [
        "read:fnb"
      ],
      "meta": {
        "title": "Cari Menu",
        "showInMenu": false
      }
    },
    {
      "name": "FnBProductSearchResults",
      "path": "/fnb/search/results",
      "component": "FnBProductSearchResultsScreen",
      "permissions": [
        "read:fnb"
      ],
      "meta": {
        "title": "Hasil Pencarian",
        "showInMenu": false
      }
    },
    {
      "name": "FnBNearby",
      "path": "/fnb/nearby",
      "component": "FnBNearbyScreen",
      "permissions": [
        "read:fnb"
      ],
      "meta": {
        "title": "Resto Terdekat",
        "showInMenu": false
      }
    },
    {
      "name": "FnBCheapDelivery",
      "path": "/fnb/cheap-delivery",
      "component": "FnBCheapDeliveryScreen",
      "permissions": [
        "read:fnb"
      ],
      "meta": {
        "title": "Ongkir Murah",
        "showInMenu": false
      }
    },
    {
      "name": "FnBAllMerchants",
      "path": "/fnb/all-merchants",
      "component": "FnBAllMerchantsScreen",
      "permissions": [
        "read:fnb"
      ],
      "meta": {
        "title": "Semua Merchant",
        "showInMenu": false
      }
    }
  ],
  "permissions": [
    "read:fnb",
    "write:fnb"
  ]
}