{
  "name": "member-closepay-expo",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:web": "expo export -p web && npx workbox-cli generateSW workbox-config.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "perf:typecheck": "node scripts/run-with-timing.js tsc --noEmit",
    "perf:lint": "node scripts/run-with-timing.js npm run lint",
    "perf:build": "node scripts/run-with-timing.js npx expo export -p web",
    "perf:build:android": "node scripts/run-with-timing.js npx expo export -p android",
    "perf:build:ios": "node scripts/run-with-timing.js npx expo export -p ios",
    "perf:bundle:web": "EXPO_ATLAS=true npx expo export -p web && npx expo-atlas .expo/atlas.jsonl",
    "perf:bundle:android": "EXPO_ATLAS=true npx expo export -p android && npx expo-atlas .expo/atlas.jsonl",
    "perf:bundle:ios": "EXPO_ATLAS=true npx expo export -p ios && npx expo-atlas .expo/atlas.jsonl",
    "postinstall": "node -e \"var fs=require('fs'); var p='node_modules/react-native-linear-gradient/index.web.js'; var s='shim-linear-gradient.web.js'; if(fs.existsSync(s)) fs.copyFileSync(s,p);\""
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-clipboard/clipboard": "^1.16.3",
    "@react-native-masked-view/masked-view": "0.3.2",
    "@react-navigation/bottom-tabs": "^7.14.0",
    "@react-navigation/drawer": "^7.8.1",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/native-stack": "^7.13.0",
    "axios": "^1.13.5",
    "babel-plugin-module-resolver": "^2.1.1",
    "base-64": "^1.0.0",
    "expo": "~55.0.3",
    "expo-application": "~55.0.8",
    "expo-camera": "~55.0.9",
    "expo-clipboard": "~55.0.8",
    "expo-constants": "~55.0.7",
    "expo-font": "~55.0.4",
    "expo-image-manipulator": "~55.0.9",
    "expo-image-picker": "~55.0.9",
    "expo-linear-gradient": "~55.0.8",
    "expo-location": "~55.1.2",
    "expo-notifications": "~55.0.10",
    "expo-secure-store": "~55.0.8",
    "expo-status-bar": "~55.0.4",
    "freerasp-react-native": "^4.3.2",
    "iconsax-react-nativejs": "^0.0.8",
    "jsqr": "^1.4.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-ble-plx": "^3.3.0",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-image-picker": "^8.2.1",
    "react-native-keyboard-aware-scroll-view": "^0.9.5",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-maps": "1.26.20",
    "react-native-nfc-manager": "^3.15.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-skeleton-placeholder": "^5.2.4",
    "react-native-svg": "15.15.3",
    "react-native-toast-message": "^2.3.3",
    "react-native-vision-camera": "^4.6.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.2",
    "zustand": "^5.0.11"
  },
  "overrides": {
    "react-native-worklets": "0.7.2",
    "react-native-skeleton-placeholder": {
      "@react-native-masked-view/masked-view": "0.3.2"
    }
  },
  "devDependencies": {
    "@types/react": "~19.2.10",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "babel-preset-expo": "~55.0.8",
    "eslint": "^9.39.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "typescript": "~5.9.2",
    "workbox-cli": "^7.4.0"
  },
  "private": true
}
